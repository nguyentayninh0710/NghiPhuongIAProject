    private void loadDashboardData() {
        loadCurrentClasses();
        loadCreatedQuizzes();
    }

    private void loadCurrentClasses() {
        classListModel.clear();

        if (currentTeacher == null || currentTeacher.getTeacherId() == null) {
            classListModel.addElement("No teacher information found.");
            return;
        }

        String sql = "SELECT ClassId, ClassName FROM `class` WHERE TeacherId = ? ORDER BY ClassName";

        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setString(1, currentTeacher.getTeacherId());

            try (ResultSet rs = ps.executeQuery()) {
                boolean hasData = false;

                while (rs.next()) {
                    hasData = true;
                    String classId = rs.getString("ClassId");
                    String className = rs.getString("ClassName");
                    classListModel.addElement(classId + " - " + className);
                }

                if (!hasData) {
                    classListModel.addElement("No classes available.");
                }
            }

        } catch (Exception e) {
            e.printStackTrace();
            classListModel.clear();
            classListModel.addElement("Error loading classes from database.");
        }
    }

    private void loadCreatedQuizzes() {
        quizListModel.clear();

        if (currentTeacher == null || currentTeacher.getTeacherId() == null) {
            quizListModel.addElement("No teacher information found.");
            return;
        }

        String sql = "SELECT QuizId, QuizTitle, Level FROM quiz WHERE TeacherId = ? ORDER BY QuizTitle";

        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            ps.setString(1, currentTeacher.getTeacherId());

            try (ResultSet rs = ps.executeQuery()) {
                boolean hasData = false;

                while (rs.next()) {
                    hasData = true;
                    String quizId = rs.getString("QuizId");
                    String quizTitle = rs.getString("QuizTitle");
                    int level = rs.getInt("Level");

                    quizListModel.addElement(quizId + " - " + quizTitle + " (Level " + level + ")");
                }

                if (!hasData) {
                    quizListModel.addElement("No quizzes created yet.");
                }
            }

        } catch (Exception e) {
            e.printStackTrace();
            quizListModel.clear();
            quizListModel.addElement("Error loading quizzes from database.");
        }
    }

